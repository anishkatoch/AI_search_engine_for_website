{
  "name": "AI Search Engine",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app/main.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install uv && uv sync && (cd frontend && npm install && npm run build) && echo '✅ Dependencies installed and frontend built'",
  "postAttachCommand": {
    "server": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8005"
  },
  "portsAttributes": {
    "8005": {
      "label": "AI Search (UI + API)",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8005
  ]
}
