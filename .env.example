# ============================================================================
# Secrets template. Copy to .env and fill in real values.
#     cp .env.example .env
# .env is git-ignored and never committed.
# ============================================================================

# OpenAI API key. Leave EMPTY to use the local HuggingFace model (free).
# When set, the app uses OpenAI embeddings (config.yaml -> models.openai_embedding).
OPEN_API_KEY=

# Optional HuggingFace READ token (https://huggingface.co/settings/tokens).
# Gives higher Hub download rate limits. NOT required — leave empty to use the
# model anonymously. Use a "read" token, never a "write" token.
HF_TOKEN=
